# OmniAgent 环境配置模板
# 复制此文件为 .env 并填写实际值

# ===== 通用配置 =====
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# ===== LLM 配置 =====
# OpenAI 兼容 API
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Qwen (通义千问)
DASHSCOPE_API_KEY=sk-xxx

# Claude
ANTHROPIC_API_KEY=sk-ant-xxx

# ===== 图片生成模块 =====
COMFYUI_HOST=http://localhost:8188
COMFYUI_WORKFLOW_DIR=./workflows/comfyui

# Flux API (如使用云端)
FLUX_API_KEY=xxx

# ===== 视频生成模块 =====
# MoneyPrinterTurbo
MONEY_PRINTER_URL=http://localhost:8501

# 视频生成 API Keys
KLING_API_KEY=xxx
SEEDANCE_API_KEY=xxx
RUNWAY_API_KEY=xxx

# ===== AI配音模块 =====
# CosyVoice
COSYVOICE_MODEL_DIR=./models/cosyvoice
COSYVOICE_DEVICE=cuda:0

# GPT-SoVITS
SOVITS_MODEL_DIR=./models/sovits
SOVITS_DEVICE=cuda:1

# FishSpeech
FISHSPEECH_API_URL=http://localhost:8080

# ===== 数字人模块 =====
# LiveTalking
LIVETALKING_HOST=http://localhost:8888
LIVETALKING_MODEL_DIR=./models/livetalking

# Duix-Avatar
DUIX_MODEL_DIR=./models/duix

# ===== 存储配置 =====
STORAGE_TYPE=local  # local | s3 | oss
STORAGE_PATH=./data/output
S3_BUCKET=xxx
S3_ACCESS_KEY=xxx
S3_SECRET_KEY=xxx
S3_ENDPOINT=xxx

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== PostgreSQL =====
DATABASE_URL=postgresql://omniagent:password@localhost:5432/omniagent
